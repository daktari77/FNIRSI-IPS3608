# Normalize line endings: store text as LF in the repo, check out native.
* text=auto

# Source and docs: always LF in the working tree too (kills the CRLF warnings).
*.py   text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf
*.cfg  text eol=lf
*.spec text eol=lf

# Windows-native scripts: keep CRLF.
*.ps1  text eol=crlf
*.bat  text eol=crlf

# Binary assets: never touch.
*.ttf  binary
*.pdf  binary
*.png  binary
*.jpg  binary
*.ico  binary
*.exe  binary
*.dll  binary
